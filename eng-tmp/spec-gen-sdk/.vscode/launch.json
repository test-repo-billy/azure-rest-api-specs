{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
      {
        "type": "node",
        "request": "launch",
        "name": "Launch spec-gen-sdk",
        "program": "${workspaceFolder}/dist/cli/cli.js",
        "args": [
          "--wf=/home/raychen/repos/tmp/sdkauto",
          "--local-spec-repo-path=/home/raychen/repos/github/azure-rest-api-specs",//forked/test-repo-billy/azure-rest-api-specs",
          "--local-sdk-repo-path=/home/raychen/repos/github/azure-sdk-for-java",
          //"--n=32294",//3578",
          "--spec-commit-sha=84f223e8bea800a1a0b503b8c28675abf91f92a2",// cecc8f818cbd313aaa99f83e394159e4361b883a",
          "--spec-repo-https-url=https://github.com/azure/azure-rest-api-specs",
          "--sdk-repo-name=azure-sdk-for-java",
          "--tsp-config-relative-path=specification/contosowidgetmanager/Contoso.WidgetManager/tspconfig.yaml"
        ],
        "outputCapture": "std",
        "skipFiles": [
          "<node_internals>/**"
        ]
      },
      {
        "type": "node",
        "name": "vscode-jest-tests",
        "request": "launch",
        "program": "${workspaceFolder}/node_modules/jest/bin/jest",
        "args": [
          "-i",
          "--config",
          "jest.config.integration.js"
        ],
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen",
        "disableOptimisticBPs": true
      }
    ]
  }
  